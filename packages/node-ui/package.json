{
  "name": "@dkg/node-ui",
  "version": "0.0.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && pnpm build:ui",
    "build:ui": "cross-env NODE_OPTIONS=--max-old-space-size=4096 vite build",
    "dev:ui": "vite",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@dkg/core": "workspace:*",
    "@dkg/graph-viz": "workspace:*",
    "better-sqlite3": "^11"
  },
  "devDependencies": {
    "@codemirror/lang-sql": "^6",
    "@codemirror/state": "^6",
    "@codemirror/view": "^6",
    "@dkg/graph-viz": "workspace:*",
    "@types/better-sqlite3": "^7",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^4",
    "cross-env": "^10.1.0",
    "react": "^19",
    "react-dom": "^19",
    "react-router-dom": "^7",
    "recharts": "^2",
    "three": "^0.182.0",
    "typescript": "^5.7",
    "vite": "^6",
    "vitest": "^3"
  }
}
