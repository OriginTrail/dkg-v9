# === AI Models / Systems (100 triples) ===

dkg:model-gpt-4 a schema:SoftwareApplication ;
  schema:name "GPT-4" ;
  schema:creator dkg:org-openai ;
  schema:datePublished "2023-03-14"^^xsd:date ;
  schema:applicationCategory dkg:field-llm ;
  schema:description "Multimodal large language model" ;
  dkg:parameterCount "1.8T (estimated)" ;
  dkg:architecture "Transformer (MoE)" .

dkg:model-gpt-4o a schema:SoftwareApplication ;
  schema:name "GPT-4o" ;
  schema:creator dkg:org-openai ;
  schema:datePublished "2024-05-13"^^xsd:date ;
  schema:applicationCategory dkg:field-llm ;
  schema:description "Omni model with native audio, vision, and text" ;
  schema:isBasedOn dkg:model-gpt-4 .

dkg:model-claude-3 a schema:SoftwareApplication ;
  schema:name "Claude 3" ;
  schema:creator dkg:org-anthropic ;
  schema:datePublished "2024-03-04"^^xsd:date ;
  schema:applicationCategory dkg:field-llm ;
  schema:description "Family of models focused on safety and helpfulness" ;
  dkg:variants "Haiku, Sonnet, Opus" .

dkg:model-claude-4 a schema:SoftwareApplication ;
  schema:name "Claude 4" ;
  schema:creator dkg:org-anthropic ;
  schema:datePublished "2025-05-22"^^xsd:date ;
  schema:applicationCategory dkg:field-llm ;
  schema:isBasedOn dkg:model-claude-3 ;
  dkg:variants "Haiku, Sonnet, Opus" .

dkg:model-gemini a schema:SoftwareApplication ;
  schema:name "Gemini" ;
  schema:creator dkg:org-deepmind ;
  schema:datePublished "2023-12-06"^^xsd:date ;
  schema:applicationCategory dkg:field-llm ;
  schema:description "Natively multimodal model" ;
  dkg:variants "Nano, Pro, Ultra" .

dkg:model-llama-3 a schema:SoftwareApplication ;
  schema:name "Llama 3" ;
  schema:creator dkg:org-meta-ai ;
  schema:datePublished "2024-04-18"^^xsd:date ;
  schema:applicationCategory dkg:field-llm ;
  schema:description "Open-weight large language model" ;
  schema:license "Llama 3 Community License" ;
  dkg:parameterCount "8B, 70B, 405B" .

dkg:model-mistral-large a schema:SoftwareApplication ;
  schema:name "Mistral Large" ;
  schema:creator dkg:org-mistral ;
  schema:datePublished "2024-02-26"^^xsd:date ;
  schema:applicationCategory dkg:field-llm ;
  dkg:architecture "Transformer" .

dkg:model-mixtral a schema:SoftwareApplication ;
  schema:name "Mixtral 8x7B" ;
  schema:creator dkg:org-mistral ;
  schema:datePublished "2023-12-11"^^xsd:date ;
  schema:applicationCategory dkg:field-mixture-of-experts ;
  schema:license "Apache 2.0" ;
  dkg:parameterCount "46.7B (12.9B active)" ;
  dkg:architecture "Sparse Mixture of Experts" .

dkg:model-stable-diffusion-3 a schema:SoftwareApplication ;
  schema:name "Stable Diffusion 3" ;
  schema:creator dkg:org-stability-ai ;
  schema:datePublished "2024-06-12"^^xsd:date ;
  schema:applicationCategory dkg:field-diffusion-models ;
  dkg:architecture "Multimodal Diffusion Transformer (MMDiT)" .

dkg:model-alphafold a schema:SoftwareApplication ;
  schema:name "AlphaFold" ;
  schema:creator dkg:org-deepmind ;
  schema:datePublished "2020-11-30"^^xsd:date ;
  schema:applicationCategory dkg:field-protein-folding ;
  schema:description "Predicts protein 3D structures with atomic accuracy" ;
  schema:award "Breakthrough of the Year 2021" .

dkg:model-alphafold-3 a schema:SoftwareApplication ;
  schema:name "AlphaFold 3" ;
  schema:creator dkg:org-deepmind ;
  schema:datePublished "2024-05-08"^^xsd:date ;
  schema:applicationCategory dkg:field-protein-folding ;
  schema:isBasedOn dkg:model-alphafold ;
  schema:description "Predicts structures of all biological molecules" .

dkg:model-command-r-plus a schema:SoftwareApplication ;
  schema:name "Command R+" ;
  schema:creator dkg:org-cohere ;
  schema:datePublished "2024-04-04"^^xsd:date ;
  schema:applicationCategory dkg:field-rag ;
  schema:description "Optimized for retrieval augmented generation and tool use" ;
  dkg:parameterCount "104B" .

