{
  "name": "@dkg/adapter-openclaw",
  "version": "0.0.1",
  "description": "OpenClaw plugin adapter — turns any OpenClaw agent into a DKG V9 node",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "skills",
    "openclaw-entry.mjs",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@dkg/agent": "workspace:*",
    "@dkg/core": "workspace:*",
    "@dkg/storage": "workspace:*"
  },
  "openclaw": {
    "extensions": ["./openclaw-entry.mjs"]
  },
  "bundledDependencies": ["@dkg/agent", "@dkg/core", "@dkg/storage"],
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "vitest": "^4.0.18"
  }
}
