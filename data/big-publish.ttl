  schema:description "Introduced the Transformer architecture that became the foundation of modern AI" .

dkg:paper-alphafold-2020 a schema:ScholarlyArticle ;
  schema:name "Highly accurate protein structure prediction with AlphaFold" ;
  schema:datePublished "2021-07-15"^^xsd:date ;
  schema:about dkg:field-protein-folding ;
  schema:author dkg:person-john-jumper, dkg:person-demis-hassabis ;
  schema:publisher "Nature" ;
  schema:description "Achieved protein structure prediction at experimental accuracy" .

dkg:paper-gpt-4-technical-report a schema:ScholarlyArticle ;
  schema:name "GPT-4 Technical Report" ;
  schema:datePublished "2023-03-15"^^xsd:date ;
