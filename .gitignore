# Claude Code: ignore everything per-developer EXCEPT the project config
# (settings.json) and the agent-scope hooks. Both are needed across the
# whole team for hard enforcement to attach in Claude Code.
.claude/*
!.claude/settings.json
!.claude/hooks/
.claude/settings.local.json

# agent-scope: never commit the bootstrap override or local audit logs
agent-scope/.bootstrap-token
agent-scope/logs/
