{
  "name": "dkg-app-origin-trail-game",
  "version": "0.1.0",
  "description": "OriginTrail Game — a multiplayer game on the DKG. Installable DKG app.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "dkgApp": {
    "id": "origin-trail-game",
    "label": "OriginTrail Game",
    "apiHandler": "./dist/api/handler.js",
    "staticDir": "./dist-ui"
  },
  "scripts": {
    "build": "tsc && pnpm build:ui",
    "build:api": "tsc",
    "build:ui": "cross-env NODE_OPTIONS=--max-old-space-size=4096 vite build",
    "dev:ui": "vite",
    "test": "vitest run",
    "test:ui": "vitest run --config vitest.ui.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "clean": "rm -rf dist dist-ui tsconfig.tsbuildinfo"
  },
  "peerDependencies": {
    "@dkg/agent": "workspace:*",
    "@dkg/core": "workspace:*",
    "@dkg/storage": "workspace:*"
  },
  "dependencies": {
    "@dkg/graph-viz": "workspace:*",
    "ethers": "^6",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^9",
    "@vitejs/plugin-react": "^4",
    "happy-dom": "^20.8.3",
    "react": "^19",
    "react-dom": "^19",
    "react-router-dom": "^7",
    "typescript": "^5.7",
    "vite": "^6",
    "vitest": "^3"
  }
}
