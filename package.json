{
  "name": "dkg-v9",
  "version": "9.0.0",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "dev": "turbo dev",
    "dkg": "node packages/cli/dist/cli.js",
    "devnet": "./scripts/devnet.sh",
    "devnet:start": "./scripts/devnet.sh start",
    "devnet:stop": "./scripts/devnet.sh stop",
    "devnet:status": "./scripts/devnet.sh status",
    "devnet:clean": "./scripts/devnet.sh clean",
    "sim": "pnpm --filter @dkg/network-sim dev",
    "sim:testnet": "SIM_TARGET=testnet pnpm --filter @dkg/network-sim dev",
    "sim:build": "pnpm --filter @dkg/network-sim build",
    "mcp": "node packages/mcp-server/dist/index.js",
    "index": "node packages/cli/dist/cli.js index"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@vitest/coverage-v8": "^3",
    "tsx": "^4.21.0",
    "turbo": "^2",
    "typescript": "^5.7",
    "vitest": "^3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "oxigraph",
      "protobufjs"
    ],
    "overrides": {
      "axios@<1.8.2": "1.8.2",
      "minimatch@<10.2.3": "10.2.3",
      "serialize-javascript@<7.0.3": "7.0.3",
      "bn.js@<4.12.3": "4.12.3",
      "undici@>=7.0.0 <7.18.2": "7.18.2",
      "cookie@<0.7.0": "0.7.0",
      "tmp@<0.2.4": "0.2.4"
    },
    "patchedDependencies": {
      "hardhat@2.28.6": "patches/hardhat@2.28.6.patch"
    }
  }
}
