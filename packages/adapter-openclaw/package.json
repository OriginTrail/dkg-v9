{
  "name": "@origintrail-official/dkg-adapter-openclaw",
  "version": "0.0.1",
  "description": "OpenClaw plugin adapter — turns any OpenClaw agent into a DKG V9 node",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "skills",
    "openclaw-entry.mjs",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@origintrail-official/dkg-core": "workspace:*"
  },
  "openclaw": {
    "extensions": [
      "./openclaw-entry.mjs"
    ]
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/OriginTrail/dkg-v9.git",
    "directory": "packages/adapter-openclaw"
  }
}
