# === Benchmarks & Evaluations (50 triples) ===

dkg:benchmark-mmlu a schema:DefinedTerm ;
  schema:name "MMLU" ;
  schema:description "Massive Multitask Language Understanding — 57 subjects from STEM to humanities" ;
  schema:url "https://arxiv.org/abs/2009.03300" .

dkg:benchmark-humaneval a schema:DefinedTerm ;
  schema:name "HumanEval" ;
  schema:description "Code generation benchmark with 164 hand-crafted programming problems" .

dkg:benchmark-math a schema:DefinedTerm ;
  schema:name "MATH" ;
  schema:description "Competition-level mathematics problems" .

dkg:benchmark-gpqa a schema:DefinedTerm ;
  schema:name "GPQA" ;
  schema:description "Graduate-level question answering requiring expert domain knowledge" .

dkg:benchmark-arc-agi a schema:DefinedTerm ;
  schema:name "ARC-AGI" ;
  schema:description "Abstraction and Reasoning Corpus measuring fluid intelligence" ;
  schema:creator dkg:person-francois-chollet .

dkg:person-francois-chollet a foaf:Person ;
  foaf:name "Francois Chollet" ;
  schema:knowsAbout dkg:field-deep-learning ;
  schema:description "Creator of Keras and the ARC benchmark" .

dkg:eval-gpt4-mmlu a schema:Rating ;
  schema:itemReviewed dkg:model-gpt-4 ;
  schema:about dkg:benchmark-mmlu ;
  schema:ratingValue "86.4"^^xsd:decimal ;
  schema:bestRating "100"^^xsd:decimal .

dkg:eval-claude3-opus-mmlu a schema:Rating ;
  schema:itemReviewed dkg:model-claude-3 ;
  schema:about dkg:benchmark-mmlu ;
  schema:ratingValue "86.8"^^xsd:decimal ;
  schema:bestRating "100"^^xsd:decimal .

dkg:eval-gemini-ultra-mmlu a schema:Rating ;
  schema:itemReviewed dkg:model-gemini ;
  schema:about dkg:benchmark-mmlu ;
  schema:ratingValue "90.0"^^xsd:decimal ;
  schema:bestRating "100"^^xsd:decimal .

dkg:eval-llama3-405b-mmlu a schema:Rating ;
  schema:itemReviewed dkg:model-llama-3 ;
  schema:about dkg:benchmark-mmlu ;
  schema:ratingValue "88.6"^^xsd:decimal ;
  schema:bestRating "100"^^xsd:decimal .

dkg:eval-gpt4-humaneval a schema:Rating ;
  schema:itemReviewed dkg:model-gpt-4 ;
  schema:about dkg:benchmark-humaneval ;
  schema:ratingValue "67.0"^^xsd:decimal ;
  schema:bestRating "100"^^xsd:decimal .

dkg:eval-claude3-opus-humaneval a schema:Rating ;
  schema:itemReviewed dkg:model-claude-3 ;
  schema:about dkg:benchmark-humaneval ;
  schema:ratingValue "84.9"^^xsd:decimal ;
  schema:bestRating "100"^^xsd:decimal .

