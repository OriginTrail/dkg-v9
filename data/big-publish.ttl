@prefix dkg: <urn:dkg:> .
@prefix schema: <http://schema.org/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix geo: <http://www.w3.org/2003/01/geo/wgs84_pos#> .

# === AI Research Organizations (50 triples) ===

dkg:org-deepmind a schema:Organization ;
  schema:name "DeepMind" ;
  schema:foundingDate "2010-09-23"^^xsd:date ;
  schema:parentOrganization dkg:org-alphabet ;
  schema:location dkg:place-london ;
  schema:knowsAbout dkg:field-reinforcement-learning, dkg:field-protein-folding .

dkg:org-openai a schema:Organization ;
  schema:name "OpenAI" ;
  schema:foundingDate "2015-12-11"^^xsd:date ;
  schema:location dkg:place-san-francisco ;
  schema:knowsAbout dkg:field-llm, dkg:field-alignment, dkg:field-robotics .

dkg:org-anthropic a schema:Organization ;
  schema:name "Anthropic" ;
  schema:foundingDate "2021-01-28"^^xsd:date ;
  schema:location dkg:place-san-francisco ;
  schema:knowsAbout dkg:field-alignment, dkg:field-interpretability .

dkg:org-meta-ai a schema:Organization ;
  schema:name "Meta AI" ;
  schema:parentOrganization dkg:org-meta ;
  schema:location dkg:place-menlo-park ;
  schema:knowsAbout dkg:field-llm, dkg:field-computer-vision .

dkg:org-alphabet a schema:Organization ;
  schema:name "Alphabet Inc." ;
  schema:foundingDate "2015-10-02"^^xsd:date ;
  schema:location dkg:place-mountain-view .

dkg:org-meta a schema:Organization ;
  schema:name "Meta Platforms" ;
  schema:foundingDate "2004-02-04"^^xsd:date .

dkg:org-stability-ai a schema:Organization ;
  schema:name "Stability AI" ;
  schema:foundingDate "2019-01-01"^^xsd:date ;
  schema:location dkg:place-london ;
  schema:knowsAbout dkg:field-diffusion-models, dkg:field-generative-art .

dkg:org-mistral a schema:Organization ;
  schema:name "Mistral AI" ;
  schema:foundingDate "2023-04-01"^^xsd:date ;
  schema:location dkg:place-paris ;
  schema:knowsAbout dkg:field-llm, dkg:field-mixture-of-experts .

dkg:org-cohere a schema:Organization ;
  schema:name "Cohere" ;
  schema:foundingDate "2019-01-01"^^xsd:date ;
  schema:location dkg:place-toronto ;
  schema:knowsAbout dkg:field-llm, dkg:field-rag .

dkg:org-huggingface a schema:Organization ;
  schema:name "Hugging Face" ;
  schema:foundingDate "2016-01-01"^^xsd:date ;
  schema:location dkg:place-new-york ;
  schema:knowsAbout dkg:field-open-source-ml, dkg:field-transformers .

# === AI Research Fields (60 triples) ===

dkg:field-reinforcement-learning a schema:DefinedTerm ;
  schema:name "Reinforcement Learning" ;
  schema:description "Learning through interaction with an environment via rewards and penalties" ;
  schema:isPartOf dkg:field-machine-learning ;
  owl:sameAs <https://en.wikipedia.org/wiki/Reinforcement_learning> .

dkg:field-protein-folding a schema:DefinedTerm ;
  schema:name "Protein Structure Prediction" ;
  schema:description "Predicting the 3D structure of proteins from amino acid sequences" ;
  schema:isPartOf dkg:field-computational-biology .

dkg:field-llm a schema:DefinedTerm ;
  schema:name "Large Language Models" ;
  schema:description "Neural networks trained on vast text corpora for language understanding and generation" ;
  schema:isPartOf dkg:field-nlp ;
  owl:sameAs <https://en.wikipedia.org/wiki/Large_language_model> .

dkg:field-alignment a schema:DefinedTerm ;
  schema:name "AI Alignment" ;
  schema:description "Ensuring AI systems behave in accordance with human values and intentions" ;
  schema:isPartOf dkg:field-ai-safety .

dkg:field-interpretability a schema:DefinedTerm ;
  schema:name "Mechanistic Interpretability" ;
  schema:description "Understanding the internal mechanisms of neural networks" ;
  schema:isPartOf dkg:field-ai-safety .

dkg:field-computer-vision a schema:DefinedTerm ;
  schema:name "Computer Vision" ;
  schema:description "Enabling machines to interpret and understand visual information" ;
  schema:isPartOf dkg:field-machine-learning .

dkg:field-diffusion-models a schema:DefinedTerm ;
  schema:name "Diffusion Models" ;
  schema:description "Generative models that learn to denoise data through iterative refinement" ;
  schema:isPartOf dkg:field-generative-ai .

dkg:field-generative-art a schema:DefinedTerm ;
  schema:name "Generative Art" ;
  schema:description "Art created with the assistance of AI generative systems" .

dkg:field-mixture-of-experts a schema:DefinedTerm ;
  schema:name "Mixture of Experts" ;
  schema:description "Architecture where different subnetworks specialize in different inputs" ;
  schema:isPartOf dkg:field-llm .

dkg:field-rag a schema:DefinedTerm ;
  schema:name "Retrieval Augmented Generation" ;
  schema:description "Combining retrieval systems with generative models for grounded responses" ;
  schema:isPartOf dkg:field-llm .

dkg:field-transformers a schema:DefinedTerm ;
  schema:name "Transformer Architecture" ;
  schema:description "Self-attention based architecture that revolutionized NLP and beyond" ;
  schema:isPartOf dkg:field-deep-learning .

dkg:field-machine-learning a schema:DefinedTerm ;
  schema:name "Machine Learning" ;
  schema:isPartOf dkg:field-artificial-intelligence .

dkg:field-deep-learning a schema:DefinedTerm ;
  schema:name "Deep Learning" ;
  schema:isPartOf dkg:field-machine-learning .

dkg:field-nlp a schema:DefinedTerm ;
  schema:name "Natural Language Processing" ;
  schema:isPartOf dkg:field-artificial-intelligence .

dkg:field-ai-safety a schema:DefinedTerm ;
  schema:name "AI Safety" ;
  schema:isPartOf dkg:field-artificial-intelligence .

dkg:field-generative-ai a schema:DefinedTerm ;
  schema:name "Generative AI" ;
  schema:isPartOf dkg:field-deep-learning .

dkg:field-computational-biology a schema:DefinedTerm ;
  schema:name "Computational Biology" .

dkg:field-artificial-intelligence a schema:DefinedTerm ;
  schema:name "Artificial Intelligence" .

dkg:field-open-source-ml a schema:DefinedTerm ;
  schema:name "Open Source Machine Learning" ;
  schema:isPartOf dkg:field-machine-learning .

dkg:field-robotics a schema:DefinedTerm ;
  schema:name "Robotics" ;
  schema:isPartOf dkg:field-artificial-intelligence .

